# Copy this file to .env and fill in real values for your environment.
# core/settings.py reads these via os.environ — wire up python-dotenv
# in manage.py / wsgi.py if you want .env auto-loaded locally.

DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

# Set to True in production and fill in Postgres creds below
USE_POSTGRES=False
POSTGRES_DB=motocare
POSTGRES_USER=motocare
POSTGRES_PASSWORD=motocare
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Optional integrations
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
GOOGLE_MAPS_API_KEY=

# console backend prints emails to the terminal — swap for smtp in production
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Shop identity shown on generated GST invoices — replace with your real details
SHOP_NAME=MotoCare Pro
SHOP_ADDRESS_LINE1=Plot 12, Hinjewadi Phase 1
SHOP_ADDRESS_LINE2=Pune, Maharashtra 411057, India
SHOP_PHONE=+91 12345 67890
SHOP_EMAIL=support@motocarepro.example
SHOP_GSTIN=27AAAAA0000A1Z5
SHOP_STATE=Maharashtra
GST_RATE_PERCENT=18
